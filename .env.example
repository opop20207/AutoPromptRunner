# Example AutoPromptRunner environment variables.
#
# Copy to `.env` and edit. These AUTOPROMPT_* variables override the TOML config file
# (which overrides the built-in defaults). They are NON-SECRET operational settings only --
# do NOT put credentials or tokens here; AutoPromptRunner never reads secrets from config
# or the environment.

# Path to a TOML config file (overrides the search order).
# AUTOPROMPT_CONFIG=autoprompt.toml

# SQLite database path.
# AUTOPROMPT_DB_PATH=.autoprompt/autoprompt.db

# Default run settings.
# AUTOPROMPT_DEFAULT_PROVIDER=mock
# AUTOPROMPT_DEFAULT_WORKSPACE=
# AUTOPROMPT_MAX_LOOPS_DEFAULT=5
# AUTOPROMPT_TIMEOUT_SECONDS_DEFAULT=1800

# Safety hard limits.
# AUTOPROMPT_MAX_LOOPS_HARD_LIMIT=20
# AUTOPROMPT_TIMEOUT_SECONDS_HARD_LIMIT=7200

# Background queue worker.
# AUTOPROMPT_QUEUE_POLL_INTERVAL_SECONDS=2

# Local HTTP API.
# AUTOPROMPT_API_HOST=127.0.0.1
# AUTOPROMPT_API_PORT=8000

# Git worktrees base directory.
# AUTOPROMPT_WORKTREE_BASE_DIR=.autoprompt/worktrees

# Optional local API token auth (disabled by default). The API binds to 127.0.0.1 by
# default; if you bind it to 0.0.0.0 or otherwise expose it, ENABLE AUTH. AUTOPROMPT_API_TOKEN
# is the ONE exception to the "no secrets here" rule above -- keep this file out of version
# control (.env is gitignored). Generate a token with: autoprompt-runner auth token generate
# AUTOPROMPT_AUTH_ENABLED=false
# AUTOPROMPT_API_TOKEN=
# AUTOPROMPT_ALLOW_UNAUTHENTICATED_HEALTH=true
